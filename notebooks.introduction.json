{"version":3,"kind":"Notebook","sha256":"5c00be4778dfadd7f57df891b68afb6c21c97916dda80ce73d1edbde34c73df1","slug":"notebooks.introduction","location":"/notebooks/introduction.ipynb","dependencies":[],"frontmatter":{"title":"MPAS Viewer","content_includes_title":true,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"The visualization of MPAS data","given":"The","non_dropping_particle":"visualization of","family":"MPAS data"},"name":"The visualization of MPAS data","id":"contributors-myst-generated-uid-0"}],"open_access":true,"license":{"content":{"id":"CC-BY-4.0","url":"https://creativecommons.org/licenses/by/4.0/","name":"Creative Commons Attribution 4.0 International","free":true,"CC":true},"code":{"id":"Apache-2.0","url":"https://opensource.org/licenses/Apache-2.0","name":"Apache License 2.0","free":true,"osi":true}},"github":"https://github.com/projectpythia/mpasviewer-cookbook","copyright":"2026","affiliations":[{"id":"UAlbany","name":"University at Albany (SUNY)","department":"Atmospheric and Environmental Sciences","url":"https://www.albany.edu/daes"},{"id":"CISL","name":"NSF National Center for Atmospheric Research","department":"Computational and Information Systems Lab","url":"https://www.cisl.ucar.edu"},{"id":"Unidata","name":"NSF Unidata","url":"https://www.unidata.ucar.edu"},{"id":"Argonne","name":"Argonne National Laboratory","department":"Environmental Science Division","url":"https://www.anl.gov/evs"},{"id":"CarbonPlan","name":"CarbonPlan","url":"https://carbonplan.org"},{"id":"NVIDIA","name":"NVIDIA Corporation","url":"https://www.nvidia.com/"}],"numbering":{"title":{"offset":1}},"source_url":"https://github.com/projectpythia/mpasviewer-cookbook/blob/main/notebooks/introduction.ipynb","edit_url":"https://github.com/projectpythia/mpasviewer-cookbook/edit/main/notebooks/introduction.ipynb","thumbnail":"/mpasviewer-cookbook/build/wrfandmpas-a64b3e341a14077953acae35279e1114.png","exports":[{"format":"ipynb","filename":"introduction.ipynb","url":"/mpasviewer-cookbook/build/introduction-ac0709d5a25eac5be21584e9a037597a.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[],"key":"ANtwX1E60l"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":1,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"MPAS Viewer","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"dCpjejVicr"}],"identifier":"mpas-viewer","label":"MPAS Viewer","html_id":"mpas-viewer","implicit":true,"key":"VUPFBMJDag"},{"type":"thematicBreak","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"sxTBIhez3Y"},{"type":"heading","depth":3,"position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"What is MPAS-A?","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"UfnuoLfu4y"}],"identifier":"what-is-mpas-a","label":"What is MPAS-A?","html_id":"what-is-mpas-a","implicit":true,"key":"eYy2cZC0Vz"},{"type":"paragraph","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"The Model for Prediction Across Scales Atmosphere (MPAS-A) is an atmospheric model designed to represent weather systems across a wide range of spatial scales. Its defining feature is a variable-resolution mesh that allows regions of interest to be simulated at higher resolution while maintaining a coarser resolution elsewhere. This flexibility helps MPAS-A capture both large-scale atmospheric patterns and smaller-scale weather features.","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"nk3yVfJG8K"}],"key":"uqm16HHTMj"},{"type":"thematicBreak","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"qTex4QHCMm"},{"type":"heading","depth":3,"position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"Why is Visualization Challenging?","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"aetGhtmntf"}],"identifier":"why-is-visualization-challenging","label":"Why is Visualization Challenging?","html_id":"why-is-visualization-challenging","implicit":true,"key":"vZ5gEYAHW7"},{"type":"paragraph","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"While the MPAS mesh gives the model a lot of flexibility, it also makes visualization more challenging. Unlike traditional gridded datasets, MPAS-A output does not fit neatly into a regular latitude-longitude grid. This means that common plotting workflows often require extra steps to properly handle the mesh structure.","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"vozLtxU9gp"}],"key":"RQeNR9IpvH"},{"type":"thematicBreak","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"Yrcn87wONz"},{"type":"heading","depth":3,"position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"Why MPAS Viewer?","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"K020jm3juB"}],"identifier":"why-mpas-viewer","label":"Why MPAS Viewer?","html_id":"why-mpas-viewer","implicit":true,"key":"CqRFKUefpr"},{"type":"paragraph","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"text","value":"MPAS Viewer was developed to make this process easier. It provides tools and workflows for exploring MPAS-A output, creating visualizations, and working with model data without needing to focus as much on the details of the underlying mesh.","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"zxz94WdvXI"}],"key":"XCGqUvuvdg"},{"type":"blockquote","position":{"start":{"line":22,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":22,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"strong","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"text","value":"Why use MPAS Viewer?","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"WwHvZjgAme"}],"key":"nBnTuzM9U9"},{"type":"break","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"eOl5hW6RiL"},{"type":"text","value":"MPAS Viewer helps users quickly inspect simulations, visualize unstructured mesh data, create figures, generate animations, and build reproducible workflows.","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"ZvbS4IXhnN"}],"key":"VFdmB4Gfem"}],"key":"CUFjRPREO8"},{"type":"thematicBreak","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"Pjs6jnn1tN"}],"key":"GEwgsf5Ygn"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Why MPAS Instead of WRF?","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"A45lRU4GXu"}],"identifier":"why-mpas-instead-of-wrf","label":"Why MPAS Instead of WRF?","html_id":"why-mpas-instead-of-wrf","implicit":true,"key":"FFlQFfpwpB"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"WRF is one of the most widely used atmospheric models and remains an important tool for weather research and forecasting. However, MPAS-A was designed to address some challenges that can arise when modeling weather systems across large domains and multiple spatial scales.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"oY1UKXZPXL"}],"key":"LXhwE5OFid"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"One major difference is the grid structure. WRF commonly uses a structured latitude-longitude grid, while MPAS-A uses an unstructured Voronoi mesh.\nIn simple terms, a Voronoi mesh divides the model domain into mostly hexagonal cells, creating a flexible “honeycomb-like” grid that can smoothly vary in size across the globe. This mesh allows MPAS-A to avoid issues near the poles and scale efficiently on large computing systems.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"UNu0boyTBw"}],"key":"pg1oD3FtAf"},{"type":"paragraph","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"Another key difference is how each model handles higher-resolution regions. In WRF, increased resolution is usually added through nested domains, which can create abrupt transitions at nest boundaries. MPAS-A uses smooth grid refinement, allowing resolution to gradually change across the domain without sharp boundaries.","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"s8n19Yuax9"}],"key":"u293VpLysK"},{"type":"paragraph","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"This makes MPAS-A especially useful for simulations where both large-scale atmospheric flow and smaller-scale weather features are important. Instead of choosing between a global view and regional detail, MPAS-A provides a framework for representing both in the same simulation.","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"aSjB4gwNVI"}],"key":"mHOth7Grq9"},{"type":"table","position":{"start":{"line":12,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"tableRow","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"tableCell","header":true,"position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"WRF","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"pHHFPe6pzs"}],"key":"dYWKKMAldi"},{"type":"tableCell","header":true,"position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"MPAS-A","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"hv5aZ9Zwy8"}],"key":"UcrabhLyni"}],"key":"fHAIkTo0Sw"},{"type":"tableRow","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"tableCell","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"Structured latitude-longitude grid","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"BYqxazC0GY"}],"key":"NbLboqzZOZ"},{"type":"tableCell","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"Unstructured Voronoi mesh","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"sYzJJ9kH4r"}],"key":"kQ25xLv1vW"}],"key":"DMXhqn5YF7"},{"type":"tableRow","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"tableCell","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"Uses nested domains for higher resolution","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"exycaU6b2P"}],"key":"OBem1LcYZO"},{"type":"tableCell","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"Uses smooth variable-resolution refinement","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"P2RJCuAOio"}],"key":"x3252s47BS"}],"key":"bktf2X6oQp"},{"type":"tableRow","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"tableCell","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"Can have abrupt nest boundaries","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"BfwHhhhlK1"}],"key":"YQj31NiY0o"},{"type":"tableCell","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"Allows gradual resolution transitions","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"tf88dr1OPd"}],"key":"rWVhrvB5yN"}],"key":"hCuxLK0dPJ"},{"type":"tableRow","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"tableCell","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"Strong choice for many regional applications","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"J1HYnM6C3L"}],"key":"szPRMmB9PP"},{"type":"tableCell","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"Strong choice for global-to-regional applications","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"kETCwmv9Os"}],"key":"KQOVBrb2qG"}],"key":"VaCltWGLjB"}],"key":"NlgQLOqN3R"},{"type":"blockquote","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"strong","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"Big picture:","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"xf60wPysIb"}],"key":"vFlAabVGwc"},{"type":"text","value":" WRF and MPAS-A are both valuable atmospheric models, but MPAS-A is especially useful when the goal is to smoothly connect global-scale flow with regional or storm-scale features.","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"x0cFiBJFvL"}],"key":"xZH9e0qNTu"}],"key":"jsFuVHmIkz"}],"key":"bUeN5z5KEf"},{"type":"block","kind":"notebook-content","children":[{"type":"image","url":"/mpasviewer-cookbook/build/wrfandmpas-a64b3e341a14077953acae35279e1114.png","alt":"Comparison of WRF and MPAS grid structures","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"QEjQyyp4dx","urlSource":"./wrfandmpas.png"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"This difference in grid structure is one of the main reasons MPAS-A is powerful, but it is also why visualizing MPAS-A output requires a slightly different approach.I’m a little more tight on time than I was two months ago. That said, would we do something hosted by AMS at their building? Or would we make it an unofficial thing at a coffee shop? I couldn’t pay them, so it’d have to be word of mouth type thing and hopefully they wouldn’t get upset and instead would appreciate the business lol.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"DecWBQTK2R"}],"key":"UeJmCpcAWe"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"emphasis","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Figure 1. Comparison of WRF and MPAS grid structures. WRF uses a structured latitude-longitude grid, while MPAS uses an unstructured Voronoi/hexagonal mesh that avoids pole problems and supports efficient global modeling. Source: MPAS for WRF Users, slide 5.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"p2QGtNlFZn"}],"key":"Y3WC5dg0qD"}],"key":"f4YUW4wM7Y"},{"type":"thematicBreak","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"VT32o4LQmb"}],"key":"k8AwUm0QQc"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":