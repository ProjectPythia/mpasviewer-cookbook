{"version":3,"kind":"Notebook","sha256":"5c00be4778dfadd7f57df891b68afb6c21c97916dda80ce73d1edbde34c73df1","slug":"notebooks.introduction","location":"/notebooks/introduction.ipynb","dependencies":[],"frontmatter":{"title":"MPAS Viewer","content_includes_title":true,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"The visualization of MPAS data","given":"The","non_dropping_particle":"visualization of","family":"MPAS data"},"name":"The visualization of MPAS data","id":"contributors-myst-generated-uid-0"}],"open_access":true,"license":{"content":{"id":"CC-BY-4.0","url":"https://creativecommons.org/licenses/by/4.0/","name":"Creative Commons Attribution 4.0 International","free":true,"CC":true},"code":{"id":"Apache-2.0","url":"https://opensource.org/licenses/Apache-2.0","name":"Apache License 2.0","free":true,"osi":true}},"github":"https://github.com/projectpythia/mpasviewer-cookbook","copyright":"2026","affiliations":[{"id":"UAlbany","name":"University at Albany (SUNY)","department":"Atmospheric and Environmental Sciences","url":"https://www.albany.edu/daes"},{"id":"CISL","name":"NSF National Center for Atmospheric Research","department":"Computational and Information Systems Lab","url":"https://www.cisl.ucar.edu"},{"id":"Unidata","name":"NSF Unidata","url":"https://www.unidata.ucar.edu"},{"id":"Argonne","name":"Argonne National Laboratory","department":"Environmental Science Division","url":"https://www.anl.gov/evs"},{"id":"CarbonPlan","name":"CarbonPlan","url":"https://carbonplan.org"},{"id":"NVIDIA","name":"NVIDIA Corporation","url":"https://www.nvidia.com/"}],"numbering":{"title":{"offset":1}},"source_url":"https://github.com/projectpythia/mpasviewer-cookbook/blob/main/notebooks/introduction.ipynb","edit_url":"https://github.com/projectpythia/mpasviewer-cookbook/edit/main/notebooks/introduction.ipynb","thumbnail":"/mpasviewer-cookbook/build/wrfandmpas-0d511a19430cbc505072667c445327bd.png","exports":[{"format":"ipynb","filename":"introduction.ipynb","url":"/mpasviewer-cookbook/build/introduction-5dcd0ae6153ac13ba26dc1c8de0d06c5.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[],"key":"EFK9VW478O"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":1,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"MPAS Viewer","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ZAX6rdDO4E"}],"identifier":"mpas-viewer","label":"MPAS Viewer","html_id":"mpas-viewer","implicit":true,"key":"KvBP7UPXbL"},{"type":"thematicBreak","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"lDYCovUade"},{"type":"heading","depth":3,"position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"What is MPAS-A?","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"A5SEDkULYy"}],"identifier":"what-is-mpas-a","label":"What is MPAS-A?","html_id":"what-is-mpas-a","implicit":true,"key":"pkAFs4IE9Z"},{"type":"paragraph","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"The Model for Prediction Across Scales Atmosphere (MPAS-A) is an atmospheric model designed to represent weather systems across a wide range of spatial scales. Its defining feature is a variable-resolution mesh that allows regions of interest to be simulated at higher resolution while maintaining a coarser resolution elsewhere. This flexibility helps MPAS-A capture both large-scale atmospheric patterns and smaller-scale weather features.","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"FzpOBqT3CZ"}],"key":"rdE7Qtcv7e"},{"type":"thematicBreak","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"PSQXJCUn5j"},{"type":"heading","depth":3,"position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"Why is Visualization Challenging?","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"Oika9gboxR"}],"identifier":"why-is-visualization-challenging","label":"Why is Visualization Challenging?","html_id":"why-is-visualization-challenging","implicit":true,"key":"Uv7xTjMHsr"},{"type":"paragraph","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"While the MPAS mesh gives the model a lot of flexibility, it also makes visualization more challenging. Unlike traditional gridded datasets, MPAS-A output does not fit neatly into a regular latitude-longitude grid. This means that common plotting workflows often require extra steps to properly handle the mesh structure.","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"fae7f27rlF"}],"key":"j6kNpJR5oC"},{"type":"thematicBreak","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"ijMfVHBP64"},{"type":"heading","depth":3,"position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"Why MPAS Viewer?","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"GsYj2sDMQR"}],"identifier":"why-mpas-viewer","label":"Why MPAS Viewer?","html_id":"why-mpas-viewer","implicit":true,"key":"zwgDVJuaVb"},{"type":"paragraph","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"text","value":"MPAS Viewer was developed to make this process easier. It provides tools and workflows for exploring MPAS-A output, creating visualizations, and working with model data without needing to focus as much on the details of the underlying mesh.","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"tLPEo5TmcO"}],"key":"D48U8KmViu"},{"type":"blockquote","position":{"start":{"line":22,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":22,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"strong","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"text","value":"Why use MPAS Viewer?","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"mo3ztNVh9C"}],"key":"jaeWDKQbZY"},{"type":"break","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"a15AEW7QuH"},{"type":"text","value":"MPAS Viewer helps users quickly inspect simulations, visualize unstructured mesh data, create figures, generate animations, and build reproducible workflows.","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"vRHpY64g2I"}],"key":"IlIaBStPl7"}],"key":"fBUCVVMRhg"},{"type":"thematicBreak","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"yAKZBGclnl"}],"key":"T3BJjHS0H2"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Why MPAS Instead of WRF?","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"WAk0iUGzmT"}],"identifier":"why-mpas-instead-of-wrf","label":"Why MPAS Instead of WRF?","html_id":"why-mpas-instead-of-wrf","implicit":true,"key":"O6G8duEXif"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"WRF is one of the most widely used atmospheric models and remains an important tool for weather research and forecasting. However, MPAS-A was designed to address some challenges that can arise when modeling weather systems across large domains and multiple spatial scales.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"ce9SKoXswf"}],"key":"zkMl92JqSs"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"One major difference is the grid structure. WRF commonly uses a structured latitude-longitude grid, while MPAS-A uses an unstructured Voronoi mesh.\nIn simple terms, a Voronoi mesh divides the model domain into mostly hexagonal cells, creating a flexible “honeycomb-like” grid that can smoothly vary in size across the globe. This mesh allows MPAS-A to avoid issues near the poles and scale efficiently on large computing systems.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"OvDbtDZM5O"}],"key":"DNLMeOmeDn"},{"type":"paragraph","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"Another key difference is how each model handles higher-resolution regions. In WRF, increased resolution is usually added through nested domains, which can create abrupt transitions at nest boundaries. MPAS-A uses smooth grid refinement, allowing resolution to gradually change across the domain without sharp boundaries.","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"vTKjJZAu7k"}],"key":"imo03Xs3uY"},{"type":"paragraph","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"This makes MPAS-A especially useful for simulations where both large-scale atmospheric flow and smaller-scale weather features are important. Instead of choosing between a global view and regional detail, MPAS-A provides a framework for representing both in the same simulation.","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"fsctQefRSa"}],"key":"hc59Th57kG"},{"type":"table","position":{"start":{"line":12,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"tableRow","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"tableCell","header":true,"position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"WRF","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"nCASBueuMA"}],"key":"yGOzEiYZvR"},{"type":"tableCell","header":true,"position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"MPAS-A","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"WghhyNpQW1"}],"key":"iiqGuvgXac"}],"key":"kZJxDXsljm"},{"type":"tableRow","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"tableCell","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"Structured latitude-longitude grid","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"gHyL0uYb4r"}],"key":"dcZ00fegpw"},{"type":"tableCell","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"Unstructured Voronoi mesh","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"ma5RCwlLu7"}],"key":"IzxztLWTV5"}],"key":"dQOR9gGI50"},{"type":"tableRow","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"tableCell","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"Uses nested domains for higher resolution","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"igwkOPK5TT"}],"key":"W1kmGctiBl"},{"type":"tableCell","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"Uses smooth variable-resolution refinement","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"PScbb8dCA8"}],"key":"grt9cLav6M"}],"key":"FJenWNFyP8"},{"type":"tableRow","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"tableCell","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"Can have abrupt nest boundaries","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"hGXL7I9jGG"}],"key":"qLuxzA3neq"},{"type":"tableCell","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"Allows gradual resolution transitions","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"qk0HalQOfb"}],"key":"dmaogAt1Rq"}],"key":"DBokgLnkrI"},{"type":"tableRow","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"tableCell","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"Strong choice for many regional applications","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"FRECloCtZ9"}],"key":"xpCzoU4s4S"},{"type":"tableCell","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"Strong choice for global-to-regional applications","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"Ip8DJ3dKaf"}],"key":"qVGoM8Cz8x"}],"key":"ikUlEITmpV"}],"key":"VPMgSpZyfN"},{"type":"blockquote","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"strong","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"Big picture:","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"vFXYtLO4zY"}],"key":"MttGrzlS36"},{"type":"text","value":" WRF and MPAS-A are both valuable atmospheric models, but MPAS-A is especially useful when the goal is to smoothly connect global-scale flow with regional or storm-scale features.","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"l45M68etSg"}],"key":"yibAgBTAWB"}],"key":"sRhMW0U701"}],"key":"Jool96zpYu"},{"type":"block","kind":"notebook-content","children":[{"type":"image","url":"/mpasviewer-cookbook/build/wrfandmpas-0d511a19430cbc505072667c445327bd.png","alt":"Comparison of WRF and MPAS grid structures","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Aeu4KaVu6X","urlSource":"./wrfandmpas.png"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"This difference in grid structure is one of the main reasons MPAS-A is powerful, but it is also why visualizing MPAS-A output requires a slightly different approach.I’m a little more tight on time than I was two months ago. That said, would we do something hosted by AMS at their building? Or would we make it an unofficial thing at a coffee shop? I couldn’t pay them, so it’d have to be word of mouth type thing and hopefully they wouldn’t get upset and instead would appreciate the business lol.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"diEZ8csbvv"}],"key":"FOZkNMwHB8"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"emphasis","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Figure 1. Comparison of WRF and MPAS grid structures. WRF uses a structured latitude-longitude grid, while MPAS uses an unstructured Voronoi/hexagonal mesh that avoids pole problems and supports efficient global modeling. Source: MPAS for WRF Users, slide 5.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"tRLpBCxYgg"}],"key":"AhWJ0QW6SQ"}],"key":"XOkt0phQ73"},{"type":"thematicBreak","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"N6uQVZHknu"}],"key":"aZGQCzBmEy"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":