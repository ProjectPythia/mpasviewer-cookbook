{"version":3,"kind":"Notebook","sha256":"90e63e415e3a16ff6f33d92c2e1774325f565671047093b63f33a08232a13656","slug":"notebooks.introduction","location":"/notebooks/introduction.ipynb","dependencies":[],"frontmatter":{"title":"MPAS Viewer","content_includes_title":true,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"The visualization of MPAS data","given":"The","non_dropping_particle":"visualization of","family":"MPAS data"},"name":"The visualization of MPAS data","id":"contributors-myst-generated-uid-0"}],"open_access":true,"license":{"content":{"id":"CC-BY-4.0","url":"https://creativecommons.org/licenses/by/4.0/","name":"Creative Commons Attribution 4.0 International","free":true,"CC":true},"code":{"id":"Apache-2.0","url":"https://opensource.org/licenses/Apache-2.0","name":"Apache License 2.0","free":true,"osi":true}},"github":"https://github.com/projectpythia/mpasviewer-cookbook","copyright":"2026","affiliations":[{"id":"UAlbany","name":"University at Albany (SUNY)","department":"Atmospheric and Environmental Sciences","url":"https://www.albany.edu/daes"},{"id":"CISL","name":"NSF National Center for Atmospheric Research","department":"Computational and Information Systems Lab","url":"https://www.cisl.ucar.edu"},{"id":"Unidata","name":"NSF Unidata","url":"https://www.unidata.ucar.edu"},{"id":"Argonne","name":"Argonne National Laboratory","department":"Environmental Science Division","url":"https://www.anl.gov/evs"},{"id":"CarbonPlan","name":"CarbonPlan","url":"https://carbonplan.org"},{"id":"NVIDIA","name":"NVIDIA Corporation","url":"https://www.nvidia.com/"}],"numbering":{"title":{"offset":1}},"source_url":"https://github.com/projectpythia/mpasviewer-cookbook/blob/main/notebooks/introduction.ipynb","edit_url":"https://github.com/projectpythia/mpasviewer-cookbook/edit/main/notebooks/introduction.ipynb","exports":[{"format":"ipynb","filename":"introduction.ipynb","url":"/mpasviewer-cookbook/build/introduction-e1799ba9d0ce954fa8722a09ed3dc76c.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[],"key":"CxzWoJ05XO"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":1,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"MPAS Viewer","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"UewYrs8DuE"}],"identifier":"mpas-viewer","label":"MPAS Viewer","html_id":"mpas-viewer","implicit":true,"key":"wsHAKh2Kna"},{"type":"thematicBreak","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"tpEukDxcqb"},{"type":"heading","depth":3,"position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"What is MPAS-A?","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"YgtEmhouwH"}],"identifier":"what-is-mpas-a","label":"What is MPAS-A?","html_id":"what-is-mpas-a","implicit":true,"key":"GeGyIwr4JS"},{"type":"paragraph","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"The Model for Prediction Across Scales Atmosphere (MPAS-A) is an atmospheric model designed to represent weather systems across a wide range of spatial scales. Its defining feature is a variable-resolution mesh that allows regions of interest to be simulated at higher resolution while maintaining a coarser resolution elsewhere. This flexibility helps MPAS-A capture both large-scale atmospheric patterns and smaller-scale weather features.","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"OKl5J5zoHx"}],"key":"YM8uo8Y3fU"},{"type":"thematicBreak","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"WlrFtAQwE4"},{"type":"heading","depth":3,"position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"Why is Visualization Challenging?","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"AemDoiWEut"}],"identifier":"why-is-visualization-challenging","label":"Why is Visualization Challenging?","html_id":"why-is-visualization-challenging","implicit":true,"key":"HwDe7cLccu"},{"type":"paragraph","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"While the MPAS mesh gives the model a lot of flexibility, it also makes visualization more challenging. Unlike traditional gridded datasets, MPAS-A output does not fit neatly into a regular latitude-longitude grid. This means that common plotting workflows often require extra steps to properly handle the mesh structure.","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"R539SCMGm0"}],"key":"Nip0URe2Ba"},{"type":"thematicBreak","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"bV8RPbjlTN"},{"type":"heading","depth":3,"position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"Why MPAS Viewer?","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"zAQ786qOpn"}],"identifier":"why-mpas-viewer","label":"Why MPAS Viewer?","html_id":"why-mpas-viewer","implicit":true,"key":"lu6AnZJiFf"},{"type":"paragraph","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"text","value":"MPAS Viewer was developed to make this process easier. It provides tools and workflows for exploring MPAS-A output, creating visualizations, and working with model data without needing to focus as much on the details of the underlying mesh.","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"cOlf2fXzLr"}],"key":"jPqOjTl3oa"},{"type":"blockquote","position":{"start":{"line":22,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":22,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"strong","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"text","value":"Why use MPAS Viewer?","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"KhCGXiu30F"}],"key":"ySG092IgKv"},{"type":"break","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"nQAUr90QOS"},{"type":"text","value":"MPAS Viewer helps users quickly inspect simulations, visualize unstructured mesh data, create figures, generate animations, and build reproducible workflows.","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"e9EtCSMNfJ"}],"key":"i7ryZeX4pr"}],"key":"WNqmTEcChy"},{"type":"thematicBreak","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"XqvgZbzfIP"}],"key":"xs0pknyA2r"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Why MPAS Instead of WRF?","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"N9HL4nUoHw"}],"identifier":"why-mpas-instead-of-wrf","label":"Why MPAS Instead of WRF?","html_id":"why-mpas-instead-of-wrf","implicit":true,"key":"QKsualCddZ"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"WRF is one of the most widely used atmospheric models and remains an important tool for weather research and forecasting. However, MPAS-A was designed to address some challenges that can arise when modeling weather systems across large domains and multiple spatial scales.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"yycphp3NkV"}],"key":"DW2AEFFcu5"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"One major difference is the grid structure. WRF commonly uses a structured latitude-longitude grid, while MPAS-A uses an unstructured Voronoi mesh.\nIn simple terms, a Voronoi mesh divides the model domain into mostly hexagonal cells, creating a flexible “honeycomb-like” grid that can smoothly vary in size across the globe. This mesh allows MPAS-A to avoid issues near the poles and scale efficiently on large computing systems.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"UrV8bD22RI"}],"key":"PAVAVwqGhp"},{"type":"paragraph","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"Another key difference is how each model handles higher-resolution regions. In WRF, increased resolution is usually added through nested domains, which can create abrupt transitions at nest boundaries. MPAS-A uses smooth grid refinement, allowing resolution to gradually change across the domain without sharp boundaries.","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"H7WFSxd4Q0"}],"key":"F5XAyioEvT"},{"type":"paragraph","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"This makes MPAS-A especially useful for simulations where both large-scale atmospheric flow and smaller-scale weather features are important. Instead of choosing between a global view and regional detail, MPAS-A provides a framework for representing both in the same simulation.","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"r0pUf9IDfE"}],"key":"cQxwqr4sus"},{"type":"table","position":{"start":{"line":12,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"tableRow","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"tableCell","header":true,"position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"WRF","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"Xt6VDU0EV9"}],"key":"DX2Uj4t1Rq"},{"type":"tableCell","header":true,"position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"MPAS-A","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"Ib2mplQR7M"}],"key":"dhDXJrwfAf"}],"key":"zfaA1Tl6HA"},{"type":"tableRow","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"tableCell","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"Structured latitude-longitude grid","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"VyNTstHFKF"}],"key":"DQNsjByunu"},{"type":"tableCell","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"Unstructured Voronoi mesh","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"ZL5xWsoxtZ"}],"key":"kdMP9YvBT4"}],"key":"yanzBKXOe7"},{"type":"tableRow","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"tableCell","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"Uses nested domains for higher resolution","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"hAlR3uPxMV"}],"key":"KYBLcQDynC"},{"type":"tableCell","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"Uses smooth variable-resolution refinement","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"XbX3jaPg1p"}],"key":"ekBoQieK2c"}],"key":"O2feV5CmYJ"},{"type":"tableRow","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"tableCell","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"Can have abrupt nest boundaries","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"eLFUF6BkBW"}],"key":"XsO8bAXmTY"},{"type":"tableCell","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"Allows gradual resolution transitions","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"iYH0qLKr9V"}],"key":"DqnCOiiwp4"}],"key":"CJioNk2kmh"},{"type":"tableRow","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"tableCell","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"Strong choice for many regional applications","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"PPkOsHt7yJ"}],"key":"gXszDViD28"},{"type":"tableCell","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"Strong choice for global-to-regional applications","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"CDT4nNA6aS"}],"key":"TFkQ43vqBS"}],"key":"xW4tvShGka"}],"key":"j1jVy6GLbx"},{"type":"blockquote","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"strong","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"Big picture:","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"zCj6ZoZcjN"}],"key":"zXsYV2cmtf"},{"type":"text","value":" WRF and MPAS-A are both valuable atmospheric models, but MPAS-A is especially useful when the goal is to smoothly connect global-scale flow with regional or storm-scale features.","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"fFZbNrkcSR"}],"key":"zS5aOiQRSf"}],"key":"r2vsxGugQn"}],"key":"kanP27nSd3"},{"type":"block","kind":"notebook