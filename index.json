/build/71ba35e43a79d3c84c9de3253d6c1939.svg","key":"Ip5zbiwidN","urlSource":"https://contrib.rocks/image?repo=ProjectPythia/mpasviewer-cookbook"}],"urlSource":"https://github.com/ProjectPythia/mpasviewer-cookbook/graphs/contributors","error":true,"key":"RJH5ydx0u3"},{"type":"heading","depth":2,"position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"text","value":"Structure","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"LuPGrz8geB"}],"identifier":"structure","label":"Structure","html_id":"structure","implicit":true,"key":"ovbgUBY577"},{"type":"paragraph","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"text","value":"This practical development manual serves as an example of how to collect, manage, and present various MPAS-A data.","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"Fz6XduPB44"}],"key":"WcltP0cg6V"},{"type":"heading","depth":3,"position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"children":[{"type":"text","value":"Foundations","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"XGJ6moWQd7"}],"identifier":"foundations","label":"Foundations","html_id":"foundations","implicit":true,"key":"J68UJ1M71G"},{"type":"paragraph","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"children":[{"type":"text","value":"The ","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"lhOLbpKvQt"},{"type":"strong","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"children":[{"type":"text","value":"Model for Prediction Across Scales Atmosphere (MPAS-A)","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"HGW6uBGFtw"}],"key":"UdedZmW5jk"},{"type":"text","value":" is an advanced atmospheric model designed to represent weather systems across both regional and global scales. Its defining feature is the use of an unstructured, variable-resolution mesh, often described as a honeycomb-like grid, which allows high resolution in regions of interest while maintaining coarser resolution elsewhere. This design enables MPAS-A to efficiently capture fine-scale phenomena such as convection and storms without sacrificing the ability to simulate large-scale atmospheric dynamics.","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"gZ5zisVJIv"}],"key":"Tfrm4glo88"},{"type":"paragraph","position":{"start":{"line":46,"column":1},"end":{"line":46,"column":1}},"children":[{"type":"text","value":"Despite these advantages, the unstructured nature of the MPAS mesh introduces challenges for data visualization and analysis. Although MPAS-A outputs are stored in NetCDF format, they cannot be treated like conventional gridded raster data. Proper handling of the data requires knowledge of the mesh connectivity, including vertices, edges, and cell centroids, which complicates otherwise straightforward visualization tasks. As a result, rapid inspection and exploratory analysis of MPAS-A outputs can become time-consuming and technically demanding.","position":{"start":{"line":46,"column":1},"end":{"line":46,"column":1}},"key":"eCqoq41Tqa"}],"key":"KqoYH6bHaH"},{"type":"heading","depth":3,"position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"children":[{"type":"text","value":"Example workflows","position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"key":"oHUSfdS1eb"}],"identifier":"example-workflows","label":"Example workflows","html_id":"example-workflows","implicit":true,"key":"hkhuqwHnpv"},{"type":"paragraph","position":{"start":{"line":50,"column":1},"end":{"line":50,"column":1}},"children":[{"type":"text","value":"Several notebooks with the following structure can be found in the notebooks directory:","position":{"start":{"line":50,"column":1},"end":{"line":50,"column":1}},"key":"FhX6BnO4ys"}],"key":"G8Wt0BntHM